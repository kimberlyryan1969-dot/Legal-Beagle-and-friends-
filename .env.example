# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo

# LLM Configuration
LLM_PROVIDER=openai  # options: openai, anthropic, local
LLM_TEMPERATURE=0.3

# Database Configuration
DATABASE_TYPE=sqlite  # options: sqlite, postgresql, mysql
DATABASE_PATH=./data/legal_cases.db

# Case Law API Configuration
GOOGLE_SCHOLAR_API_KEY=your_api_key_here
PACER_USERNAME=your_pacer_username
PACER_PASSWORD=your_pacer_password

# Document Output
OUTPUT_DIRECTORY=./output/documents
DOCUMENT_FORMAT=pdf  # options: pdf, docx, txt

# Logging
LOG_LEVEL=INFO  # options: DEBUG, INFO, WARNING, ERROR
LOG_FILE=./logs/legal_beagle.log

# Research Parameters
MAX_SEARCH_RESULTS=50
CASE_LAW_YEARS_BACK=20
JURISDICTION=federal  # options: federal, state, all
